<!DOCTYPE html>
<html lang="ar" dir="rtl" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content="Final AI - مساعد ذكاء اصطناعي متكامل بواجهة حديثة واحترافية" />
  <meta name="theme-color" content="#0b0f14" />
  <title>Final AI — المساعد الذكي</title>

  <link rel="icon" type="image/svg+xml" href="assets/img/favicon.svg" />
  <link rel="manifest" href="manifest.json" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Markdown / Highlight / LaTeX / Sanitizer -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/styles/atom-one-dark.min.css" id="hljs-theme" />

  <link rel="stylesheet" href="assets/css/style.css" />
</head>
<body>
  <div class="app" id="app">

    <!-- ===== Sidebar ===== -->
    <aside class="sidebar" id="sidebar" aria-label="سجل المحادثات">
      <div class="sidebar-header">
        <div class="brand">
          <div class="brand-logo" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
              <rect x="2" y="2" width="28" height="28" rx="8" fill="var(--accent)"/>
              <path d="M10 22V10h12v3.5h-8v2h7V19h-7v3z" fill="var(--accent-foreground)"/>
            </svg>
          </div>
          <span class="brand-name">Final AI</span>
        </div>
        <button class="icon-btn sidebar-close" id="sidebar-close" aria-label="إغلاق القائمة الجانبية">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <button class="new-chat-btn" id="new-chat-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        <span>محادثة جديدة</span>
      </button>

      <div class="search-box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" id="chat-search" placeholder="بحث في المحادثات..." aria-label="بحث في المحادثات" />
      </div>

      <nav class="chat-list" id="chat-list" aria-label="قائمة المحادثات"></nav>

      <div class="sidebar-footer">
        <button class="footer-btn" id="theme-toggle" aria-label="تبديل المظهر">
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <span class="theme-label">المظهر</span>
        </button>
        <button class="footer-btn" id="settings-btn" aria-label="الإعدادات">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
          <span>الإعدادات</span>
        </button>
      </div>
    </aside>

    <div class="sidebar-overlay" id="sidebar-overlay" aria-hidden="true"></div>

    <!-- ===== Main ===== -->
    <main class="main">
      <header class="topbar">
        <button class="icon-btn" id="sidebar-open" aria-label="فتح القائمة الجانبية">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="topbar-title" id="topbar-title">Final AI</h1>
        <div class="topbar-badge">
          <span class="pulse-dot" aria-hidden="true"></span>
          <span>متصل</span>
        </div>
      </header>

      <!-- Chat area -->
      <section class="chat-area" id="chat-area" aria-live="polite">
        <div class="messages" id="messages">
          <!-- Welcome screen -->
          <div class="welcome" id="welcome">
            <div class="welcome-logo" aria-hidden="true">
              <svg width="52" height="52" viewBox="0 0 32 32" fill="none">
                <rect x="2" y="2" width="28" height="28" rx="8" fill="var(--accent)"/>
                <path d="M10 22V10h12v3.5h-8v2h7V19h-7v3z" fill="var(--accent-foreground)"/>
              </svg>
            </div>
            <h2 class="welcome-title text-balance">مرحبًا بك في Final AI</h2>
            <p class="welcome-sub text-pretty">مساعدك الذكي للإجابة عن الأسئلة، تحليل الملفات، وكتابة الأكواد البرمجية</p>
            <div class="suggestions" id="suggestions">
              <button class="suggestion" data-prompt="اشرح لي مفهوم الذكاء الاصطناعي التوليدي بشكل مبسط">
                <span class="suggestion-title">اشرح مفهومًا</span>
                <span class="suggestion-desc">الذكاء الاصطناعي التوليدي بشكل مبسط</span>
              </button>
              <button class="suggestion" data-prompt="أنشئ لي صفحة هبوط HTML احترافية لمتجر إلكتروني">
                <span class="suggestion-title">أنشئ مشروعًا</span>
                <span class="suggestion-desc">صفحة هبوط لمتجر إلكتروني</span>
              </button>
              <button class="suggestion" data-prompt="اكتب دالة Python لفرز قائمة باستخدام خوارزمية Quick Sort مع شرح الخطوات">
                <span class="suggestion-title">اكتب كودًا</span>
                <span class="suggestion-desc">خوارزمية Quick Sort في Python</span>
              </button>
              <button class="suggestion" data-prompt="لخّص لي أهم النقاط في الملف المرفق">
                <span class="suggestion-title">حلّل ملفًا</span>
                <span class="suggestion-desc">ارفع ملفًا واطلب تلخيصه</span>
              </button>
            </div>
          </div>
        </div>
        <button class="scroll-bottom-btn" id="scroll-bottom-btn" aria-label="الانتقال لأسفل المحادثة">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        </button>
      </section>

      <!-- Composer -->
      <footer class="composer-wrap">
        <div class="drop-overlay" id="drop-overlay" aria-hidden="true">
          <div class="drop-inner">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            <p>أفلت الملفات هنا لإرفاقها</p>
          </div>
        </div>
        <div class="composer glass" id="composer">
          <div class="attachments" id="attachments"></div>
          <div class="composer-row">
            <button class="icon-btn attach-btn" id="attach-btn" aria-label="إرفاق ملفات">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
            </button>
            <textarea id="prompt-input" rows="1" placeholder="اسأل Final AI أي شيء..." aria-label="اكتب رسالتك"></textarea>
            <button class="send-btn" id="send-btn" aria-label="إرسال" disabled>
              <svg class="icon-send" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="transform:scaleX(-1)"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              <svg class="icon-stop" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="5" y="5" width="14" height="14" rx="2"/></svg>
            </button>
          </div>
          <input type="file" id="file-input" multiple hidden
            accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.json,.xml,.html,.css,.js,.ts,.jsx,.tsx,.java,.c,.cpp,.h,.hpp,.cs,.py,.php,.go,.rs,.kt,.swift,.zip,.rar,.md,.yml,.yaml,.sql,.sh,image/*" />
        </div>
        <p class="composer-note">قد يُخطئ Final AI أحيانًا؛ تحقّق من المعلومات المهمة.</p>
      </footer>
    </main>
  </div>

  <!-- ===== Settings modal ===== -->
  <div class="modal-backdrop" id="settings-modal" hidden>
    <div class="modal glass" role="dialog" aria-modal="true" aria-labelledby="settings-title">
      <div class="modal-header">
        <h2 id="settings-title">الإعدادات</h2>
        <button class="icon-btn" id="settings-close" aria-label="إغلاق">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="modal-body">
        <label class="field">
          <span class="field-label">رابط خادم Cloudflare Worker</span>
          <input type="url" id="worker-url-input" dir="ltr" placeholder="https://final-ai.example.workers.dev" />
          <span class="field-hint">يتم الاتصال بالنموذج عبر هذا الرابط فقط. مفتاح API محفوظ بأمان داخل Cloudflare ولا يظهر للمستخدم أبدًا.</span>
        </label>
        <div class="danger-zone">
          <button class="danger-btn" id="clear-all-btn">حذف جميع المحادثات</button>
        </div>
      </div>
      <div class="modal-footer">
        <button class="primary-btn" id="settings-save">حفظ</button>
      </div>
    </div>
  </div>

  <!-- ===== Confirm dialog ===== -->
  <div class="modal-backdrop" id="confirm-modal" hidden>
    <div class="modal glass modal-sm" role="alertdialog" aria-modal="true" aria-labelledby="confirm-title">
      <div class="modal-body">
        <h2 id="confirm-title" class="confirm-title">تأكيد الحذف</h2>
        <p id="confirm-text" class="confirm-text">هل أنت متأكد؟</p>
      </div>
      <div class="modal-footer">
        <button class="ghost-btn" id="confirm-cancel">إلغاء</button>
        <button class="danger-btn" id="confirm-ok">حذف</button>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toasts" aria-live="polite"></div>

  <!-- Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/marked@14.1.3/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.7/dist/purify.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.10.0/build/highlight.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

  <!-- App -->
  <script src="assets/js/config.js"></script>
  <script src="assets/js/files.js"></script>
  <script src="assets/js/app.js"></script>
</body>
</html>
